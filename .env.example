# Connection string Postgres (Neon) - obrigatório para mensagens e amizades persistirem
# Local: copie para .env e preencha. Square Cloud: defina POSTGRES_URL nas variáveis de ambiente do app
POSTGRES_URL=postgresql://user:password@host/db?sslmode=require
# Opcional
PORT=3000
SESSION_SECRET=seu-segredo-aqui
