# PostgreSQL — Liberty
# Copie para .env e preencha (nunca commite .env).
# Em produção (Square Cloud, etc.): defina DATABASE_URL nas variáveis de ambiente do painel do host.

# URL do banco (Neon: use a connection string do painel; pode incluir ?sslmode=require):
# DATABASE_URL=postgresql://usuario:senha@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=
JWT_SECRET=seu_segredo_jwt_aqui
