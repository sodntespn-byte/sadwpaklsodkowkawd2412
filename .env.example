# PostgreSQL — Neon ou Square Cloud
# Copie para .env e preencha com sua URL (nunca commite .env no Git).

# Neon (use connection pooler e SSL):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Square Cloud (variável que eles injetam no deploy):
# BANCO_DADOS=postgresql://user:password@host:port/database

# Use uma das variáveis (o código aceita qualquer uma):
DATABASE_URL=
# BANCO_DADOS=
# DB_URL=

# Opcional
PORT=80
JWT_SECRET=seu_segredo_jwt_aqui
