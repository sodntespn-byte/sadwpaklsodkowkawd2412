# ============================================
# VoiceRoom — Environment Variables Example
# Copy this file to .env and fill in values
# ============================================

# ---- Database ----
DATABASE_URL="postgresql://voiceroom:voiceroom_pass@localhost:5432/voiceroom"

# ---- Server ----
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ---- JWT ----
JWT_ACCESS_SECRET=change_me_access_super_secret_32_chars_min
JWT_REFRESH_SECRET=change_me_refresh_super_secret_32_chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Optional: Accept Liberty JWT (app principal) ----
# Set to the same value as libertyrealreal backend JWT_SECRET
# LIBERTY_JWT_SECRET=change_me_liberty_super_secret_32_chars_min

# ---- TURN/STUN ----
# Your coturn server address (can be localhost for dev)
TURN_SERVER_URL=turn:localhost:3478
TURN_USERNAME=voiceroom
TURN_PASSWORD=voiceroom_turn_pass
# Public STUN servers (Google, free for dev/test)
STUN_SERVER_URL=stun:stun.l.google.com:19302

# ---- Rate Limiting ----
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# ---- Logging ----
LOG_LEVEL=info

# ---- Rooms ----
DEFAULT_ROOM_MAX_CAPACITY=10

# ---- Optional: Transcription (future) ----
# TRANSCRIPT_API_KEY=
# TRANSCRIPT_API_URL=

# ---- PostgreSQL Docker (used by docker-compose) ----
POSTGRES_USER=voiceroom
POSTGRES_PASSWORD=voiceroom_pass
POSTGRES_DB=voiceroom

# ---- coturn Docker (used by docker-compose) ----
COTURN_REALM=voiceroom.local
COTURN_AUTH_USER=voiceroom
COTURN_AUTH_PASS=voiceroom_turn_pass
